or":15,"minor":0}},{"domain":"macCatalyst","introduced":{"major":26,"minor":0}},{"domain":"iOS","introduced":{"major":18,"minor":0}},{"domain":"visionOS","isUnconditionallyUnavailable":true},{"domain":"tvOS","isUnconditionallyUnavailable":true},{"domain":"watchOS","isUnconditionallyUnavailable":true}]},{"kind":{"identifier":"swift.method","displayName":"Instance Method"},"identifier":{"precise":"s:7SwiftUI4ViewP013_Translation_aB0E15translationTask6source6target17preferredStrategy6actionQr10Foundation6LocaleV8LanguageVSg_AO0D00D7SessionC0J0VyARYactF","interfaceLanguage":"swift"},"pathComponents":["View","translationTask(source:target:preferredStrategy:action:)"],"names":{"title":"translationTask(source:target:preferredStrategy:action:)","subHeading":[{"kind":"keyword","spelling":"func"},{"kind":"text","spelling":" "},{"kind":"identifier","spelling":"translationTask"},{"kind":"text","spelling":"("},{"kind":"externalParam","spelling":"source"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"Locale","preciseIdentifier":"s:10Foundation6LocaleV"},{"kind":"text","spelling":"."},{"kind":"typeIdentifier","spelling":"Language","preciseIdentifier":"s:10Foundation6LocaleV8LanguageV"},{"kind":"text","spelling":"?, "},{"kind":"externalParam","spelling":"target"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"Locale","preciseIdentifier":"s:10Foundation6LocaleV"},{"kind":"text","spelling":"."},{"kind":"typeIdentifier","spelling":"Language","preciseIdentifier":"s:10Foundation6LocaleV8LanguageV"},{"kind":"text","spelling":"?, "},{"kind":"externalParam","spelling":"preferredStrategy"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"TranslationSession","preciseIdentifier":"s:11Translation0A7SessionC"},{"kind":"text","spelling":"."},{"kind":"typeIdentifier","spelling":"Strategy","preciseIdentifier":"s:11Translation0A7SessionC8StrategyV"},{"kind":"text","spelling":", "},{"kind":"externalParam","spelling":"action"},{"kind":"text","spelling":": ("},{"kind":"typeIdentifier","spelling":"TranslationSession","preciseIdentifier":"s:11Translation0A7SessionC"},{"kind":"text","spelling":") "},{"kind":"keyword","spelling":"async"},{"kind":"text","spelling":" -> "},{"kind":"typeIdentifier","spelling":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","spelling":") -> "},{"kind":"keyword","spelling":"some"},{"kind":"text","spelling":" "},{"kind":"typeIdentifier","spelling":"View","preciseIdentifier":"s:7SwiftUI4ViewP"},{"kind":"text","spelling":"\n"}]},"docComment":{"module":"_Translation_SwiftUI","lines":[{"text":"Adds a task to perform before this view appears or when the specified source or target"},{"text":"languages change."},{"text":""},{"text":"This task provides an instance of <doc://com.apple.documentation/documentation/translation/translationsession> to use to perform translations."},{"text":""},{"text":"Perform new translations with the same `source` and `target` language, use <doc://com.apple.documentation/documentation/swiftui/view/translationtask(_:action:)>"},{"text":"and call <doc://com.apple.documentation/documentation/translation/translationsession/configuration/invalidate()>."},{"text":""},{"text":"For example, you can translate when content appears:"},{"text":""},{"text":"     struct ContentView: View {"},{"text":"         var sourceText = \"Hallo, Welt!\""},{"text":"         var sourceLanguage: Locale.Language?"},{"text":"         var targetLanguage: Locale.Language?"},{"text":""},{"text":"         @State private var targetText: String?"},{"text":""},{"text":"         var body: some View {"},{"text":"             Text(targetText ?? sourceText)"},{"text":"                 .translationTask("},{"text":"                     source: sourceLanguage,"},{"text":"                     target: targetLanguage,"},{"text":"                     preferredStrategy: .lowLatency"},{"text":"                 ) { session in"},{"text":"                     Task { @MainActor in"},{"text":"                         do {"},{"text":"                             let response = try await session.translate(sourceText)"},{"text":"                             targetText = response.targetText"},{"text":"                         } catch {"},{"text":"                             // code to handle error"},{"text":"                         }"},{"text":"                     }"},{"text":"                 }"},{"text":"         }"},{"text":"     }"},{"text":""},{"text":"The system throws a `fatalError` if you use a <doc://com.apple.documentation/documentation/translation/translationsession> instance after the attached view disappears or if you use it after"},{"text":"changing the `source` or `target` parameters. This causes the `action` closure to provide a new instance."},{"text":""},{"text":"- Parameters:"},{"text":"    - source: The language the source content is in. If this is `nil`, the session tries to"},{"text":"        identify the language and prompts the person to pick the source language if it's unclear. All"},{"text":"        text translated within the session should be in the same source language. Changing this"},{"text":"        value cancels previous tasks and creates a new session to perform translations again."},{"text":"    - target: The language to translate content into. A `nil` value means the session picks a"},{"text":"        target according to the person's `Locale.preferredLanguages` and the `source`."},{"text":"        Changing this value cancels previous tasks and creates a new one to perform"},{"text":"        translations again."},{"text":"    - preferredStrategy: The translation strategy to use. ``TranslationSession/Strategy/highFidelity``"},{"text":"        provides more fluent translations using Apple Intelligence models when available,"},{"text":"        or traditional models otherwise. ``TranslationSession/Strategy/lowLatency``"},{"text":"        uses traditional models. Each strategy supports different sets of languages."},{"text":"    - action: A closure that runs when the view first appears and when `source` or"},{"text":"        `target` change.  It provides a <doc://com.apple.documentation/documentation/translation/translationsession> instance to perform one or more translations."}]},"functionSignature":{"parameters":[{"name":"source","declarationFragments":[{"kind":"identifier","spelling":"source"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"Locale","preciseIdentifier":"s:10Foundation6LocaleV"},{"kind":"text","spelling":"."},{"kind":"typeIdentifier","spelling":"Language","preciseIdentifier":"s:10Foundation6LocaleV8LanguageV"},{"kind":"text","spelling":"?"}]},{"name":"target","declarationFragments":[{"kind":"identifier","spelling":"target"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"Locale","preciseIdentifier":"s:10Foundation6LocaleV"},{"kind":"text","spelling":"."},{"kind":"typeIdentifier","spelling":"Language","preciseIdentifier":"s:10Foundation6LocaleV8LanguageV"},{"kind":"text","spelling":"?"}]},{"name":"preferredStrategy","declarationFragments":[{"kind":"identifier","spelling":"preferredStrategy"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"TranslationSession","preciseIdentifier":"s:11Translation0A7SessionC"},{"kind":"text","spelling":"."},{"kind":"typeIdentifier","spelling":"Strategy","preciseIdentifier":"s:11Translation0A7SessionC8StrategyV"}]},{"name":"action","declarationFragments":[{"kind":"identifier","spelling":"action"},{"kind":"text","spelling":": ("},{"kind":"typeIdentifier","spelling":"TranslationSession","preciseIdentifier":"s:11Translation0A7SessionC"},{"kind":"text","spelling":") "},{"kind":"keyword","spelling":"async"},{"kind":"text","spelling":" -> "},{"kind":"typeIdentifier","spelling":"Void","preciseIdentifier":"s:s4Voida"}]}],"returns":[{"kind":"keyword","spelling":"some"},{"kind":"text","spelling":" "},{"kind":"typeIdentifier","spelling":"View","preciseIdentifier":"s:7SwiftUI4ViewP"}]},"swiftExtens