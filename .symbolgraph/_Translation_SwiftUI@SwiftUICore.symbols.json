{"metadata":{"formatVersion":{"major":0,"minor":6,"patch":0},"generator":"Apple Swift version 6.3 (swiftlang-6.3.0.123.5 clang-2100.0.123.102)"},"module":{"name":"Translation","bystanders":["SwiftUI"],"platform":{"architecture":"aarch64","vendor":"apple","operatingSystem":{"name":"macosx","minimumVersion":{"major":26,"minor":4}}}},"symbols":[{"kind":{"identifier":"swift.method","displayName":"Instance Method"},"identifier":{"precise":"s:7SwiftUI4ViewP013_Translation_aB0E23translationPresentation11isPresented4text16attachmentAnchor9arrowEdge17replacementActionQrAA7BindingVySbG_SSAA017PopoverAttachmentK0OAA0M0OySScSgtF","interfaceLanguage":"swift"},"pathComponents":["View","translationPresentation(isPresented:text:attachmentAnchor:arrowEdge:replacementAction:)"],"names":{"title":"translationPresentation(isPresented:text:attachmentAnchor:arrowEdge:replacementAction:)","subHeading":[{"kind":"keyword","spelling":"func"},{"kind":"text","spelling":" "},{"kind":"identifier","spelling":"translationPresentation"},{"kind":"text","spelling":"("},{"kind":"externalParam","spelling":"isPresented"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"Binding","preciseIdentifier":"s:7SwiftUI7BindingV"},{"kind":"text","spelling":"<"},{"kind":"typeIdentifier","spelling":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","spelling":">, "},{"kind":"externalParam","spelling":"text"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"String","preciseIdentifier":"s:SS"},{"kind":"text","spelling":", "},{"kind":"externalParam","spelling":"attachmentAnchor"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"PopoverAttachmentAnchor","preciseIdentifier":"s:7SwiftUI23PopoverAttachmentAnchorO"},{"kind":"text","spelling":", "},{"kind":"externalParam","spelling":"arrowEdge"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"Edge","preciseIdentifier":"s:7SwiftUI4EdgeO"},{"kind":"text","spelling":", "},{"kind":"externalParam","spelling":"replacementAction"},{"kind":"text","spelling":": (("},{"kind":"typeIdentifier","spelling":"String","preciseIdentifier":"s:SS"},{"kind":"text","spelling":") -> "},{"kind":"typeIdentifier","spelling":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","spelling":")?) -> "},{"kind":"keyword","spelling":"some"},{"kind":"text","spelling":" "},{"kind":"typeIdentifier","spelling":"View","preciseIdentifier":"s:7SwiftUI4ViewP"},{"kind":"text","spelling":"\n"}]},"docComment":{"module":"_Translation_SwiftUI","lines":[{"text":"Presents a translation popover when a given condition is true."},{"text":""},{"text":"Use this method to show a system UI translation popover when the `translationVisible` Boolean variable is `true`."},{"text":"Attach this view modifier to the containing view holding the text to translate."},{"text":"Then set the `isPresented` Boolean binding to `true` when you want the popover to display."},{"text":"When you do, a system UI translation popover appears offering a translation."},{"text":""},{"text":"In the example below, the popover appears when the user toggles the `translationVisible` state"},{"text":"variable by pressing the Translate button."},{"text":""},{"text":"    struct ContentView: View {"},{"text":"        @State private var translationVisible = false"},{"text":"        private var originalText = \"Hallo, Welt!\""},{"text":""},{"text":"        var body: some View {"},{"text":"            VStack {"},{"text":"                Text(verbatim: originalText)"},{"text":"                    .translationPresentation(isPresented: $translationVisible, text: originalText)"},{"text":"                Button(\"Translate\") {"},{"text":"                    translationVisible.toggle()"},{"text":"                }"},{"text":"            }"},{"text":"        }"},{"text":"    }"},{"text":""},{"text":"To replace the original text with the translation, pass in a trailing closure to the `replacementAction` parameter."},{"text":"When you do, a Replace with Translation button appears in the system UI."},{"text":"When the user taps this button, the closure returns a translation of the text as a string."},{"text":"Use that string to update the original text with the translated text as shown below:"},{"text":""},{"text":"    struct ReplaceTranslation: View {"},{"text":"        @State private var translationVisible = false"},{"text":"        @State private var originalText = \"Hallo, Welt!\""},{"text":""},{"text":"        var body: some View {"},{"text":"            VStack(spacing: 20) {"},{"text":"                TextField(\"Text to translate\", text: $originalText, axis: .vertical)"},{"text":"                    .textFieldStyle(.roundedBorder)"},{"text":"                    .translationPresentation(isPresented: $translationVisible, text: originalText) { translatedString in"},{"text":"                        // Update the original text with the translated result."},{"text":"                        originalText = translatedString"},{"text":"                    }"},{"text":"                Button(\"Translate\") {"},{"text":"                    translationVisible.toggle()"},{"text":"                }"},{"text":"            }"},{"text":"            .padding()"},{"text":"        }"},{"text":"    }"},{"text":""},{"text":"If the system can't detect the source language, it asks the user to select the language to translate from."},{"text":"For a list of supported languages see `LanguageAvailability.supportedLanguages`."},{"text":""},{"text":"While this function does support long strings of text, it works best with short ones (no more than a"},{"text":"couple of sentences or phrases in length)."},{"text":""},{"text":"- Parameters:"},{"text":"  - isPresented: A binding to a Boolean value that determines whether"},{"text":"    to present the popover."},{"text":"  - text: The text to be translated. Changing this after the popover presents has no effect."},{"text":"  - attachmentAnchor: The positioning anchor that defines the"},{"text":"    attachment point of the popover. The default is"},{"text":"    <doc://com.apple.documentation/documentation/swiftui/anchor/source/bounds>."},{"text":"  - arrowEdge: The edge of the `attachmentAnchor` that defines the"},{"text":"    location of the popover's arrow in macOS. The default is <doc://com.apple.documentation/documentation/swiftui/edge/top>."},{"text":"    iOS ignores this parameter."},{"text":"  - replacementAction: An optional action to perform when someone interacts with the \"Replace with Translation\" button. The \"Replace with Translation\" button appears when you provide this action."}]},"functionSignature":{"parameters":[{"name":"isPresented","declarationFragments":[{"kind":"identifier","spelling":"isPresented"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"Binding","preciseIdentifier":"s:7SwiftUI7BindingV"},{"kind":"text","spelling":"<"},{"kind":"typeIdentifier","spelling":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","spelling":">"}]},{"name":"text","declarationFragments":[{"kind":"identifier","spelling":"text"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"String","preciseIdentifier":"s:SS"}]},{"name":"attachmentAnchor","declarationFragments":[{"kind":"identifier","spelling":"attachmentAnchor"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"PopoverAttachmentAnchor","preciseIdentifier":"s:7SwiftUI23PopoverAttachmentAnchorO"}]},{"name":"arrowEdge","declarationFragments":[{"kind":"identifier","spelling":"arrowEdge"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"Edge","preciseIdentifier":"s:7SwiftUI4EdgeO"}]},{"name":"replacementAction","declarationFragments":[{"kind":"identifier","spelling":"replacementAction"},{"kind":"text","spelling":": (("},{"kind":"typeIdentifier","spelling":"String","preciseIdentifier":"s:SS"},{"kind":"text","spelling":") -> "},{"kind":"typeIdentifier","spelling":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","spelling":")?"}]}],"returns":[{"kind":"keyword","spelling":"some"},{"kind":"text","spelling":" "},{"kind":"typeIdentifier","spelling":"View","preciseIdentifier":"s:7SwiftUI4ViewP"}]},"swiftExtension":{"extendedModule":"SwiftUICore","typeKind":"swift.protocol"},"declarationFragments":[{"kind":"attribute","spelling":"nonisolated"},{"kind":"text","spelling":" "},{"kind":"keyword","spelling":"func"},{"kind":"text","spelling":" "},{"kind":"identifier","spelling":"translationPresentation"},{"kind":"text","spelling":"("},{"kind":"externalParam","spelling":"isPresented"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"Binding","preciseIdentifier":"s:7SwiftUI7BindingV"},{"kind":"text","spelling":"<"},{"kind":"typeIdentifier","spelling":"Bool","preciseIdentifier":"s:Sb"},{"kind":"text","spelling":">, "},{"kind":"externalParam","spelling":"text"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"String","preciseIdentifier":"s:SS"},{"kind":"text","spelling":", "},{"kind":"externalParam","spelling":"attachmentAnchor"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"PopoverAttachmentAnchor","preciseIdentifier":"s:7SwiftUI23PopoverAttachmentAnchorO"},{"kind":"text","spelling":" = .rect(.bounds), "},{"kind":"externalParam","spelling":"arrowEdge"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"Edge","preciseIdentifier":"s:7SwiftUI4EdgeO"},{"kind":"text","spelling":" = .top, "},{"kind":"externalParam","spelling":"replacementAction"},{"kind":"text","spelling":": (("},{"kind":"typeIdentifier","spelling":"String","preciseIdentifier":"s:SS"},{"kind":"text","spelling":") -> "},{"kind":"typeIdentifier","spelling":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","spelling":")? = nil) -> "},{"kind":"keyword","spelling":"some"},{"kind":"text","spelling":" "},{"kind":"typeIdentifier","spelling":"View","preciseIdentifier":"s:7SwiftUI4ViewP"},{"kind":"text","spelling":"\n"}],"accessLevel":"public","availability":[{"domain":"macOS","introduced":{"major":14,"minor":4}},{"domain":"watchOS","isUnconditionallyUnavailable":true},{"domain":"macCatalyst","isUnconditionallyUnavailable":true},{"domain":"iOS","introduced":{"major":17,"minor":4}},{"domain":"visionOS","isUnconditionallyUnavailable":true},{"domain":"tvOS","isUnconditionallyUnavailable":true}]},{"kind":{"identifier":"swift.method","displayName":"Instance Method"},"identifier":{"precise":"s:7SwiftUI4ViewP013_Translation_aB0E15translationTask_6actionQr0D00D7SessionC13ConfigurationVSg_yAIYactF","interfaceLanguage":"swift"},"pathComponents":["View","translationTask(_:action:)"],"names":{"title":"translationTask(_:action:)","subHeading":[{"kind":"keyword","spelling":"func"},{"kind":"text","spelling":" "},{"kind":"identifier","spelling":"translationTask"},{"kind":"text","spelling":"("},{"kind":"typeIdentifier","spelling":"TranslationSession","preciseIdentifier":"s:11Translation0A7SessionC"},{"kind":"text","spelling":"."},{"kind":"typeIdentifier","spelling":"Configuration","preciseIdentifier":"s:11Translation0A7SessionC13ConfigurationV"},{"kind":"text","spelling":"?, "},{"kind":"externalParam","spelling":"action"},{"kind":"text","spelling":": ("},{"kind":"typeIdentifier","spelling":"TranslationSession","preciseIdentifier":"s:11Translation0A7SessionC"},{"kind":"text","spelling":") "},{"kind":"keyword","spelling":"async"},{"kind":"text","spelling":" -> "},{"kind":"typeIdentifier","spelling":"Void","preciseIdentifier":"s:s4Voida"},{"kind":"text","spelling":") -> "},{"kind":"keyword","spelling":"some"},{"kind":"text","spelling":" "},{"kind":"typeIdentifier","spelling":"View","preciseIdentifier":"s:7SwiftUI4ViewP"},{"kind":"text","spelling":"\n"}]},"docComment":{"module":"_Translation_SwiftUI","lines":[{"text":"Adds a task to perform before this view appears or when the translation configuration changes."},{"text":""},{"text":"This task provides an instance of <doc://com.apple.documentation/documentation/translation/translationsession> to use in translations."},{"text":"Whenever <doc://com.apple.documentation/documentation/translation/translationsession/configuration>  changes and isn't `nil`, the closure `action` runs,"},{"text":"providing a session instance to perform one or more translations."},{"text":""},{"text":"For example, you can create a configuration in response to a button press to initiate the translation:"},{"text":""},{"text":"    struct ContentView: View {"},{"text":"        @State private var sourceText = \"Hallo, Welt!\""},{"text":"        var sourceLanguage: Locale.Language?"},{"text":"        var targetLanguage: Locale.Language?"},{"text":""},{"text":"        @State private var targetText: String?"},{"text":"        @State private var configuration: TranslationSession.Configuration?"},{"text":""},{"text":"        var body: some View {"},{"text":"            VStack {"},{"text":"                Text(targetText ?? sourceText)"},{"text":"                Button(\"Translate\") {"},{"text":"                    guard configuration == nil else {"},{"text":"                        configuration?.invalidate()"},{"text":"                        return"},{"text":"                    }"},{"text":""},{"text":"                     configuration = TranslationSession.Configuration("},{"text":"                        source: sourceLanguage,"},{"text":"                        target: targetLanguage)"},{"text":"                }"},{"text":"                .translationTask(configuration) { session in"},{"text":"                    Task { @MainActor in"},{"text":"                        do {"},{"text":"                            let response = try await session.translate(sourceText)"},{"text":"                            targetText = response.targetText"},{"text":"                        } catch {"},{"text":"                            // Handle any errors."},{"text":"                        }"},{"text":"                    }"},{"text":"                }"},{"text":"            }"},{"text":"        }"},{"text":"    }"},{"text":""},{"text":"The system throws a `fatalError` if you use a <doc://com.apple.documentation/documentation/translation/translationsession> instance after the attached"},{"text":"view disappears or if you use it after changing the configuration. This causes the `action` closure"},{"text":"to provide a new session instance."},{"text":""},{"text":"- Parameters:"},{"text":"    - configuration: A configuration for a <doc://com.apple.documentation/documentation/translation/translationsession>. When this configuration is non-`nil` and changes, the `action` runs providing an instance of"},{"text":"        the session to perform translations."},{"text":"    - action: This closure runs when the <doc://com.apple.documentation/documentation/translation/translationsession/configuration> is non-`nil` and changes. If the configuration is initially non-`nil`, it calls the action closure when the view appears and provides a session to perform one or more translations."}]},"functionSignature":{"parameters":[{"name":"configuration","declarationFragments":[{"kind":"identifier","spelling":"configuration"},{"kind":"text","spelling":": "},{"kind":"typeIdentifier","spelling":"TranslationSession","preciseIdentifier":"s:11Translation0A7SessionC"},{"kind":"text","spelling":"."},{"kind":"typeIdentifier","spelling":"Configuration","preciseIdentifier":"s:11Translation0A7SessionC13ConfigurationV"},{"kind":"text","spelling":"?"}]},{"name":"action","declarationFragments":[{"kind":"identifier","spelling":"action"},{"kind":"text","spelling":": ("},{"kind":"typeIdentifier","spelling":"TranslationSession","preciseIdentifier":"s:11Translation0A7SessionC"},{"kind":"text","spelling":") "},{"kind":"keyword","spelling":"async"},{"kind":"text","spelling":" -> "},{"kind":"typeIdentifier","spelling":"Void","preciseIdentifier":"s:s4Voida"}]}],"returns":[{"kind":"keyword","spelling":"some"},{"kind":"text","spelling":" "},{"kind":"typeIdentifier","spelling":"View","preciseIdentifier":"s:7Swi